{
  "name": "mesh",
  "version": "0.1.0",
  "description": "P2P LAN chat application — Electron + React/Vite",
  "main": "src/main/index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -n VITE,ELECTRON -c cyan,yellow \"npm run vite:dev\" \"npm run electron:dev\"",
    "vite:dev": "vite",
    "electron:dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "electron:preview": "electron ."
  },
  "build": {
    "appId": "com.mesh.app",
    "productName": "MESH",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**",
      "src/main/**",
      "src/preload/**",
      "src/shared/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MEmio3/MESH.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron": "^41.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.2",
    "wait-on": "^9.0.4"
  }
}
